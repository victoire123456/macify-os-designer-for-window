rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Is valid identifier helper
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Signed in check helper
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the current user is owner of the resource
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Schema and boundary controls for User Profile entity
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
        && (data.email == null || (data.email is string && data.email.size() <= 200))
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 200))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 1000))
        && (data.plan == 'free' || data.plan == 'premium')
        && (data.subscriptionStatus == 'free_tier' || data.subscriptionStatus == 'lifetime' || data.subscriptionStatus == 'pending')
        && data.createdAt is string
        && (!('momoReference' in data) || (data.momoReference is string && data.momoReference.size() <= 100))
        && (!('momoPhoneNumber' in data) || (data.momoPhoneNumber is string && data.momoPhoneNumber.size() <= 100));
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }
  }
}
